NODE_ENV=dev

# Docker Config
IMAGE_NAME=nest-service-image-v1.0
CONTAINER_NAME=nest-service-container-v1.0

PORT=4100

# Database Config
DATABASE_TYPE=mysql
DATABASE_HOST=db # localhost instead of db as local
DATABASE_PORT=3306 # 8886 instead of 3306 as local
DATABASE_USERNAME=admin
DATABASE_PASSWORD=^1Wr04yB!NF8
DATABASE_NAME=nest__service
CHARSET=utf8mb4_unicode_ci
ENTITIES=apps/tenant/src/app/modules/**/*.entity.{js,ts}
SEEDS=apps/tenant/src/app/database/seeds/**/*{.js,.ts}
MIGRATIONS=apps/tenant/src/app/database/migrations/**/*{.js,.ts}


